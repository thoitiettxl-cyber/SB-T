#!/system/bin/sh
# sbctl — SB-Tproxy management CLI

export PATH="/data/adb/magisk:/data/adb/ksu/bin:/data/adb/ap/bin:$PATH:/system/bin"

# Fixed paths — module installs to /data/adb/box/scripts regardless of invocation style
SCRIPTS_DIR="/data/adb/box/scripts"
. "${SCRIPTS_DIR}/box.tool"
SETTINGS="/data/adb/box/settings.ini"
[ -f "$SETTINGS" ] && . "$SETTINGS"

BOX_DIR="${box_dir:-/data/adb/box}"
BOX_RUN="${box_run:-${BOX_DIR}/run}"
BIN_PATH="${bin_path:-${BOX_DIR}/bin/sing-box}"
SB_CONFIG="${sing_config:-${BOX_DIR}/sing-box/config.json}"
SB_DIR="${BOX_DIR}/sing-box"

# TTY-aware colors — strip in pipes/logs
if [ -t 1 ]; then
  G="$(printf '\033[0;32m')"
  Y="$(printf '\033[1;33m')"
  R="$(printf '\033[0;31m')"
  B="$(printf '\033[0;34m')"
  NC="$(printf '\033[0m')"
else
  G="" Y="" R="" B="" NC=""
fi

info()  { printf '%b[info]%b  %s\n'  "$G" "$NC" "$*"; }
warn()  { printf '%b[warn]%b  %s\n'  "$Y" "$NC" "$*"; }
error() { printf '%b[error]%b %s\n' "$R" "$NC" "$*" >&2; }
die()   { error "$*"; exit 1; }

cmd_start()   { "$SCRIPTS_DIR/start.sh" start; }
cmd_stop()    { "$SCRIPTS_DIR/start.sh" stop; }
cmd_restart() { "$SCRIPTS_DIR/start.sh" restart; }
cmd_status()  { "$SCRIPTS_DIR/start.sh" status; }

cmd_log() {
  local target="${1:-svc}" n="${2:-20}"
  case "$n" in ''|*[!0-9]*) warn "Invalid line count '$n', using 20"; n=20 ;; esac
  local log_file
  case "$target" in
    sb|sing-box) log_file="${BOX_RUN}/sing-box.log" ;;
    net)         log_file="${BOX_RUN}/net.log" ;;
    *)           log_file="${BOX_RUN}/runs.log" ;;
  esac
  [ -f "$log_file" ] || { warn "Log not found: $log_file"; return 1; }
  tail -n "$n" "$log_file"
}

cmd_update() {
  "$SCRIPTS_DIR/upkernel.sh" "$@"
}

cmd_update_ipset() {
  "$SCRIPTS_DIR/upipset.sh" "$@"
}

cmd_ipset() {
  case "${1:-}" in
    status|check) "$SCRIPTS_DIR/ipset.sh" status ;;
    load)
      case "${2:-}" in
        ""|--force) "$SCRIPTS_DIR/ipset.sh" load "${2:-}" ;;
        *) error "Usage: sbctl ipset load [--force]"; return 1 ;;
      esac
      ;;
    *) error "Usage: sbctl ipset {status|load [--force]}"; return 1 ;;
  esac
}

cmd_config() {
  [ -x "$BIN_PATH" ] || die "Binary not found: $BIN_PATH"
  info "Checking: $SB_CONFIG"
  "$BIN_PATH" check -c "$SB_CONFIG" -D "$SB_DIR" \
    && info "Config OK" \
    || { error "Config check failed"; return 1; }
}

cmd_version() {
  [ -x "$BIN_PATH" ] || die "Binary not found: $BIN_PATH"
  "$BIN_PATH" version
}

usage() {
  printf '%bsbctl%b — SB-Tproxy management CLI\n\n' "$B" "$NC"
  printf 'Usage: sbctl <command> [options]\n\n'
  printf '%bService:%b\n'         "$Y" "$NC"
  printf '  start                  Start sing-box\n'
  printf '  stop                   Stop sing-box\n'
  printf '  restart                Restart sing-box\n'
  printf '  status                 Show running status\n\n'
  printf '%bLogs:%b\n'            "$Y" "$NC"
  printf '  log [svc|sb|net] [N]   Tail logs (default: svc, 20 lines)\n\n'
  printf '%bUpdate:%b\n'          "$Y" "$NC"
  printf '  update [opts]          Update sing-box binary (--force --pre --restart)\n'
  printf '  update-ipset [--force] Download IPSET LKMs for current kernel\n\n'
  printf '%bKernel modules:%b\n'  "$Y" "$NC"
  printf '  ipset status           Read-only IPSET/LKM compatibility report\n'
  printf '  ipset load [--force]   Load exact-matching LKMs (--force only bypasses config gate)\n\n'
  printf '%bConfig & Info:%b\n'   "$Y" "$NC"
  printf '  config                 Validate sing-box config.json\n'
  printf '  version                Show sing-box version\n'
}

case "${1:-}" in
  start)        cmd_start ;;
  stop)         cmd_stop ;;
  restart)      cmd_restart ;;
  status)       cmd_status ;;
  log)          shift; cmd_log "$@" ;;
  update)       shift; cmd_update "$@" ;;
  update-ipset) shift; cmd_update_ipset "$@" ;;
  ipset)        shift; cmd_ipset "$@" ;;
  config)       cmd_config ;;
  version)      cmd_version ;;
  --help|-h|help|"") usage ;;
  *) error "Unknown command: $1"; exit 1 ;;
esac
