#!/system/bin/sh
# Shared read-only runtime probes for lifecycle and network recovery scripts.
# This file must be sourced after box.tool so $busybox is available.

runtime_flock_wait() {
  local fd="$1"
  local timeout="$2"
  local waited=0

  while ! $busybox flock -n "$fd"; do
    [ "$waited" -ge "$timeout" ] && return 1
    sleep 1
    waited=$((waited + 1))
  done
}

runtime_pid_is_core() {
  local pid="$1"
  local expected_bin="$2"
  local cmdline first_arg

  case "$pid" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$pid" -gt 1 ] 2>/dev/null || return 1
  kill -0 "$pid" 2>/dev/null || return 1

  cmdline="${SB_PROC_ROOT:-/proc}/${pid}/cmdline"
  [ -r "$cmdline" ] || return 1
  first_arg=$($busybox tr '\000' '\n' < "$cmdline" 2>/dev/null | $busybox head -n 1)
  [ -n "$first_arg" ] && [ "$first_arg" = "$expected_bin" ]
}

_runtime_pid_socket_inodes() {
  local pid="$1"
  $busybox ls -l "${SB_PROC_ROOT:-/proc}/${pid}/fd" 2>/dev/null | $busybox awk '
    {
      marker="socket:["
      start=index($0, marker)
      if (!start) next
      value=substr($0, start + length(marker))
      finish=index(value, "]")
      if (!finish) next
      inode=substr(value, 1, finish - 1)
      if (inode ~ /^[0-9]+$/ && inode != "0") print inode
    }
  '
}

runtime_tproxy_port_ready() {
  local pid="$1"
  local port="$2"
  local require_udp="${4:-1}"
  local hex_port table inode
  local owned_inodes
  local tcp_ready=0
  local udp_ready=0

  case "$port" in
    ''|*[!0-9]*) return 1 ;;
  esac
  runtime_pid_is_core "$pid" "$3" || return 1
  [ -d "${SB_PROC_ROOT:-/proc}/${pid}/fd" ] || return 1
  hex_port=$(printf '%04X' "$port") || return 1
  owned_inodes=" $(_runtime_pid_socket_inodes "$pid" | $busybox tr '\n' ' ')"
  [ "$owned_inodes" != " " ] || return 1

  for table in tcp tcp6; do
    [ -r "${SB_PROC_ROOT:-/proc}/net/$table" ] || continue
    for inode in $($busybox awk -v port="$hex_port" '
      $2 ~ (":" port "$") && $4 == "0A" && $10 ~ /^[0-9]+$/ { print $10 }
    ' "${SB_PROC_ROOT:-/proc}/net/$table" 2>/dev/null); do
      case "$owned_inodes" in
        *" $inode "*) tcp_ready=1; break 2 ;;
      esac
    done
  done

  for table in udp udp6; do
    [ -r "${SB_PROC_ROOT:-/proc}/net/$table" ] || continue
    for inode in $($busybox awk -v port="$hex_port" '
      $2 ~ (":" port "$") && $10 ~ /^[0-9]+$/ { print $10 }
    ' "${SB_PROC_ROOT:-/proc}/net/$table" 2>/dev/null); do
      case "$owned_inodes" in
        *" $inode "*) udp_ready=1; break 2 ;;
      esac
    done
  done

  [ "$tcp_ready" -eq 1 ] || return 1
  [ "$require_udp" -eq 0 ] || [ "$udp_ready" -eq 1 ]
}

_runtime_chain_has_target() {
  local command="$1"
  local table="$2"
  local chain="$3"
  local target="$4"
  local port="$5"
  local proto="${6:-}"

  "$command" -w 5 -t "$table" -S "$chain" 2>/dev/null | $busybox awk \
    -v target="$target" -v port="$port" -v proto="$proto" '
      {
        target_ok=0
        port_ok=0
        proto_ok=0
        for (i=1; i<=NF; i++) {
          if ($i == "-j" && $(i+1) == target) target_ok=1
          if (port == "" || (($i == "--on-port" || $i == "--to-ports") && $(i+1) == port)) port_ok=1
          if (proto == "" || ($i == "-p" && $(i+1) == proto)) proto_ok=1
        }
        if (target_ok && port_ok && proto_ok) found=1
      }
      END { exit(found ? 0 : 1) }
    '
}

_runtime_chain_has_mark() {
  local command="$1"
  local table="$2"
  local chain="$3"
  local mark="$4"

  "$command" -w 5 -t "$table" -S "$chain" 2>/dev/null | $busybox awk \
    -v mark="$mark" '
      BEGIN { hex=tolower(sprintf("0x%x", mark)) }
      {
        line=tolower($0)
        if (index(line, "-j mark") &&
            (index(line, "--set-mark " mark) ||
             index(line, "--set-mark " hex) ||
             index(line, "--set-xmark " hex))) {
          found=1
        }
      }
      END { exit(found ? 0 : 1) }
    '
}

_runtime_chain_has_dns_redirect() {
  local command="$1"
  local table="$2"
  local chain="$3"
  local dns_port="$4"

  "$command" -w 5 -t "$table" -S "$chain" 2>/dev/null | $busybox awk \
    -v dns_port="$dns_port" '
      {
        proto_ok=0
        dport_ok=0
        target_ok=0
        port_ok=0
        for (i=1; i<=NF; i++) {
          if ($i == "-p" && ($(i+1) == "tcp" || $(i+1) == "udp")) proto_ok=1
          if ($i == "--dport" && $(i+1) == "53") dport_ok=1
          if ($i == "-j" && $(i+1) == "REDIRECT") target_ok=1
          if ($i == "--to-ports" && $(i+1) == dns_port) port_ok=1
        }
        if (proto_ok && dport_ok && target_ok && port_ok) found=1
      }
      END { exit(found ? 0 : 1) }
    '
}

_runtime_ipset_exists() {
  local set_name="$1"
  local ipset_bin="${SB_IPSET_BIN:-ipset}"
  local output rc

  output=$(command "$ipset_bin" list 2>/dev/null)
  rc=$?
  [ "$rc" -eq 0 ] || return 1
  printf '%s\n' "$output" | $busybox awk -v wanted="$set_name" '
    $1 == "Name:" && $2 == wanted { found=1 }
    END { exit(found ? 0 : 1) }
  '
}

_runtime_ipv6_backup_valid() {
  local backup_file="$1"

  [ -f "$backup_file" ] && [ ! -L "$backup_file" ] || return 1
  $busybox awk -F= '
    /^#/ || NF == 0 { next }
    NF != 2 { bad=1; next }
    {
      key=$1; value=$2
      if (seen[key]++) bad=1
      if (key == "accept_ra") {
        have_ra=1; if (value !~ /^(0|1|2)$/) bad=1
      } else if (key == "autoconf") {
        have_autoconf=1; if (value !~ /^(0|1)$/) bad=1
      } else if (key == "forwarding") {
        have_forwarding=1; if (value !~ /^(0|1)$/) bad=1
      } else {
        if (key !~ /^[A-Za-z0-9_.:-]+$/ || value !~ /^(0|1)$/) bad=1
        if (key == "default") have_default=1
      }
    }
    END {
      if (!have_ra || !have_autoconf || !have_forwarding || !have_default) bad=1
      exit(bad ? 1 : 0)
    }
  ' "$backup_file"
}

_runtime_policy_state_ready() {
  local command="$1"
  local family="$2"
  local mark="$3"
  local table_id="$4"
  local rules routes

  if [ "$family" = "6" ]; then
    rules=$("$command" -6 rule show 2>/dev/null) || return 1
    routes=$("$command" -6 route show table "$table_id" 2>/dev/null) || return 1
  else
    rules=$("$command" rule show 2>/dev/null) || return 1
    routes=$("$command" route show table "$table_id" 2>/dev/null) || return 1
  fi

  printf '%s\n' "$rules" | $busybox awk -v mark="$mark" -v table_id="$table_id" '
    BEGIN { wanted=tolower(sprintf("fwmark 0x%x", mark)) }
    {
      line=tolower($0)
      if (index(line, wanted) &&
          (index(line, "lookup " table_id) || index(line, "table " table_id))) {
        found=1
      }
    }
    END { exit(found ? 0 : 1) }
  ' || return 1

  printf '%s\n' "$routes" | $busybox awk '
    $1 == "local" && ($2 == "default" || $2 == "0.0.0.0/0" || $2 == "::/0") {
      for (i=1; i<=NF; i++) if ($i == "dev" && $(i+1) == "lo") found=1
    }
    END { exit(found ? 0 : 1) }
  '
}

_runtime_ipv6_disable_guard_absent() {
  local command="$1"
  local output

  output=$("$command" -w 5 -t filter -S OUTPUT 2>/dev/null) || return 1
  printf '%s\n' "$output" | $busybox awk '
    $1 == "-A" && $2 == "OUTPUT" {
      has_owner=0; uid=""; jump=""
      for (i=3; i<=NF; i++) {
        if ($i == "-m" && $(i+1) == "owner") has_owner=1
        if ($i == "--uid-owner") uid=$(i+1)
        if ($i == "-j") jump=$(i+1)
      }
      if (NF == 4 && jump == "DROP") stale=1
      if (has_owner && (uid == "0" || uid == "0-0" || uid == "root") &&
          jump == "ACCEPT") stale=1
    }
    END { exit(stale ? 1 : 0) }
  '
}

runtime_tproxy_state_classify() (
  local runtime_conf="$1"
  local port="$2"
  local ipt="${SB_IPTABLES_BIN:-iptables}"
  local ip6t="${SB_IP6TABLES_BIN:-ip6tables}"
  local ipcmd="${SB_IP_BIN:-ip}"
  local table chain target proto core_user core_group proto_port
  local line key value seen="" required
  local ipv6_disable_seen ipv6_disable_path ipv6_drift=0 runtime_dir

  [ -r "$runtime_conf" ] || exit 1
  runtime_dir=${runtime_conf%/*}
  [ ! -e "$runtime_dir/runtime_tproxy.starting" ] && \
    [ ! -L "$runtime_dir/runtime_tproxy.starting" ] || exit 1
  # runtime_tproxy.conf is generated by tproxy.sh and contains only the exact
  # values required to clean/check the mode that was actually started. Parse a
  # fixed key set rather than sourcing the file as shell code.
  CORE_USER_GROUP=""
  PROXY_TCP=""
  PROXY_UDP=""
  PROXY_TCP_PORT=""
  PROXY_UDP_PORT=""
  PROXY_IPV6=""
  BLOCK_QUIC=""
  BYPASS_CN_IP=""
  DNS_HIJACK_ENABLE=""
  DNS_PORT=""
  TABLE_ID=""
  MARK_VALUE=""
  MARK_VALUE6=""
  USE_TPROXY=""
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      \#*|'') continue ;;
      *=*) key=${line%%=*}; value=${line#*=} ;;
      *) exit 1 ;;
    esac
    case ":$seen:" in *":$key:"*) exit 1 ;; esac
    seen="${seen}:$key"
    case "$key" in
      CORE_USER_GROUP) CORE_USER_GROUP=$value ;;
      PROXY_TCP) PROXY_TCP=$value ;;
      PROXY_UDP) PROXY_UDP=$value ;;
      PROXY_TCP_PORT) PROXY_TCP_PORT=$value ;;
      PROXY_UDP_PORT) PROXY_UDP_PORT=$value ;;
      PROXY_IPV6) PROXY_IPV6=$value ;;
      BLOCK_QUIC) BLOCK_QUIC=$value ;;
      BYPASS_CN_IP) BYPASS_CN_IP=$value ;;
      DNS_HIJACK_ENABLE) DNS_HIJACK_ENABLE=$value ;;
      DNS_PORT) DNS_PORT=$value ;;
      TABLE_ID) TABLE_ID=$value ;;
      MARK_VALUE) MARK_VALUE=$value ;;
      MARK_VALUE6) MARK_VALUE6=$value ;;
      USE_TPROXY) USE_TPROXY=$value ;;
      *) : ;;
    esac
  done < "$runtime_conf"

  for required in CORE_USER_GROUP PROXY_TCP PROXY_UDP PROXY_IPV6 \
    BLOCK_QUIC BYPASS_CN_IP DNS_HIJACK_ENABLE TABLE_ID MARK_VALUE \
    MARK_VALUE6 USE_TPROXY; do
    case ":$seen:" in *":$required:"*) ;; *) exit 1 ;; esac
  done

  case "${USE_TPROXY:-}" in 0|1) ;; *) exit 1 ;; esac
  case "${PROXY_TCP:-}" in 0|1) ;; *) exit 1 ;; esac
  case "${PROXY_UDP:-}" in 0|1) ;; *) exit 1 ;; esac
  PROXY_TCP_PORT="${PROXY_TCP_PORT:-$port}"
  PROXY_UDP_PORT="${PROXY_UDP_PORT:-$port}"
  case "$PROXY_TCP_PORT:$PROXY_UDP_PORT" in *[!0-9:]*) exit 1 ;; esac
  [ "$PROXY_TCP_PORT" -ge 1 ] && [ "$PROXY_TCP_PORT" -le 65535 ] || exit 1
  [ "$PROXY_UDP_PORT" -ge 1 ] && [ "$PROXY_UDP_PORT" -le 65535 ] || exit 1
  [ "$PROXY_TCP_PORT" = "$port" ] && [ "$PROXY_UDP_PORT" = "$port" ] || exit 1
  case "${PROXY_IPV6:-}" in -1|0|1) ;; *) exit 1 ;; esac
  case "${BLOCK_QUIC:-}" in 0|1) ;; *) exit 1 ;; esac
  case "${BYPASS_CN_IP:-}" in 0|1) ;; *) exit 1 ;; esac
  case "${DNS_HIJACK_ENABLE:-}" in 0|1|2) ;; *) exit 1 ;; esac
  if [ "$DNS_HIJACK_ENABLE" -ne 0 ]; then
    case "${DNS_PORT:-}" in ''|*[!0-9]*) exit 1 ;; esac
    [ "$DNS_PORT" -ge 1 ] && [ "$DNS_PORT" -le 65535 ] || exit 1
  fi
  case "${TABLE_ID:-}" in ''|*[!0-9]*) exit 1 ;; esac
  case "${MARK_VALUE:-}" in ''|*[!0-9]*) exit 1 ;; esac
  case "${MARK_VALUE6:-}" in ''|*[!0-9]*) exit 1 ;; esac
  [ "$TABLE_ID" -ge 1 ] && [ "$TABLE_ID" -le 65535 ] || exit 1
  [ "$MARK_VALUE" -ge 1 ] && [ "$MARK_VALUE" -le 2147483647 ] || exit 1
  [ "$MARK_VALUE6" -ge 1 ] && [ "$MARK_VALUE6" -le 2147483647 ] || exit 1

  if [ "$USE_TPROXY" -eq 1 ]; then
    table="mangle"
    target="TPROXY"
  else
    table="nat"
    target="REDIRECT"
  fi
  chain="PROXY_PREROUTING"

  for proto in tcp udp; do
    [ "$proto" = "tcp" ] && [ "$PROXY_TCP" -eq 0 ] && continue
    [ "$proto" = "udp" ] && [ "$PROXY_UDP" -eq 0 ] && continue
    [ "$USE_TPROXY" -eq 0 ] && [ "$proto" = "udp" ] && continue
    proto_port="$PROXY_TCP_PORT"
    [ "$proto" = "udp" ] && proto_port="$PROXY_UDP_PORT"
    "$ipt" -w 5 -t "$table" -C PREROUTING -p "$proto" -j "$chain" 2>/dev/null || exit 1
    "$ipt" -w 5 -t "$table" -C OUTPUT -p "$proto" -j PROXY_OUTPUT 2>/dev/null || exit 1
    if [ "$USE_TPROXY" -eq 1 ]; then
      _runtime_chain_has_target "$ipt" "$table" "$chain" "$target" "$proto_port" "$proto" || exit 1
    else
      _runtime_chain_has_target "$ipt" "$table" "$chain" "$target" "$PROXY_TCP_PORT" || exit 1
    fi
  done
  if [ "$USE_TPROXY" -eq 1 ]; then
    _runtime_chain_has_mark "$ipt" "$table" PROXY_OUTPUT "$MARK_VALUE" || exit 1
  else
    _runtime_chain_has_target "$ipt" "$table" PROXY_OUTPUT "$target" "$PROXY_TCP_PORT" || exit 1
  fi

  if [ "$USE_TPROXY" -eq 1 ]; then
    _runtime_policy_state_ready "$ipcmd" 4 "$MARK_VALUE" "$TABLE_ID" || exit 1
  fi

  case "$CORE_USER_GROUP" in *:*:*) exit 1 ;; *:*) ;; *) exit 1 ;; esac
  core_user=${CORE_USER_GROUP%%:*}
  core_group=${CORE_USER_GROUP#*:}
  [ -n "$core_user" ] && [ -n "$core_group" ] || exit 1
  case "$core_user" in *[!A-Za-z0-9_.-]*) exit 1 ;; esac
  case "$core_group" in *[!A-Za-z0-9_.-]*) exit 1 ;; esac
  "$ipt" -w 5 -t filter -C OUTPUT -d 127.0.0.1 -p tcp \
    -m owner --uid-owner "$core_user" --gid-owner "$core_group" \
    -m tcp --dport "$port" -j REJECT 2>/dev/null || exit 1
  "$ip6t" -w 5 -t filter -C OUTPUT -d ::1 -p tcp \
    -m owner --uid-owner "$core_user" --gid-owner "$core_group" \
    -m tcp --dport "$port" -j REJECT 2>/dev/null || exit 1

  if [ "$PROXY_IPV6" -eq 1 ]; then
    for proto in tcp udp; do
      [ "$proto" = "tcp" ] && [ "$PROXY_TCP" -eq 0 ] && continue
      [ "$proto" = "udp" ] && [ "$PROXY_UDP" -eq 0 ] && continue
      [ "$USE_TPROXY" -eq 0 ] && [ "$proto" = "udp" ] && continue
      proto_port="$PROXY_TCP_PORT"
      [ "$proto" = "udp" ] && proto_port="$PROXY_UDP_PORT"
      "$ip6t" -w 5 -t "$table" -C PREROUTING -p "$proto" -j PROXY_PREROUTING6 2>/dev/null || exit 1
      "$ip6t" -w 5 -t "$table" -C OUTPUT -p "$proto" -j PROXY_OUTPUT6 2>/dev/null || exit 1
      if [ "$USE_TPROXY" -eq 1 ]; then
        _runtime_chain_has_target "$ip6t" "$table" PROXY_PREROUTING6 "$target" "$proto_port" "$proto" || exit 1
      else
        _runtime_chain_has_target "$ip6t" "$table" PROXY_PREROUTING6 "$target" "$PROXY_TCP_PORT" || exit 1
      fi
    done
    if [ "$USE_TPROXY" -eq 1 ]; then
      _runtime_chain_has_mark "$ip6t" "$table" PROXY_OUTPUT6 "$MARK_VALUE6" || exit 1
    else
      _runtime_chain_has_target "$ip6t" "$table" PROXY_OUTPUT6 "$target" "$PROXY_TCP_PORT" || exit 1
    fi
    [ "$USE_TPROXY" -eq 0 ] || \
      _runtime_policy_state_ready "$ipcmd" 6 "$MARK_VALUE6" "$TABLE_ID" || exit 1
  elif [ "$PROXY_IPV6" -eq -1 ]; then
    _runtime_ipv6_backup_valid "$runtime_dir/ipv6_backup.conf" || exit 1
    ipv6_disable_seen=0
    for ipv6_disable_path in "${SB_PROC_ROOT:-/proc}"/sys/net/ipv6/conf/*/disable_ipv6; do
      [ -f "$ipv6_disable_path" ] || continue
      ipv6_disable_seen=1
      [ "$(cat "$ipv6_disable_path" 2>/dev/null)" = "1" ] || ipv6_drift=1
    done
    [ "$ipv6_disable_seen" -eq 1 ] || exit 1
    [ "$(cat "${SB_PROC_ROOT:-/proc}/sys/net/ipv6/conf/all/accept_ra" 2>/dev/null)" = "0" ] || exit 1
    [ "$(cat "${SB_PROC_ROOT:-/proc}/sys/net/ipv6/conf/all/autoconf" 2>/dev/null)" = "0" ] || exit 1
    [ "$(cat "${SB_PROC_ROOT:-/proc}/sys/net/ipv6/conf/all/forwarding" 2>/dev/null)" = "0" ] || exit 1
    "$ip6t" -w 5 -t filter -C OUTPUT -m owner --uid-owner 0 -j ACCEPT 2>/dev/null || exit 1
    "$ip6t" -w 5 -t filter -C OUTPUT -j DROP 2>/dev/null || exit 1
  fi

  if [ "$PROXY_IPV6" -ne -1 ]; then
    [ ! -e "$runtime_dir/ipv6_backup.conf" ] || exit 1
    _runtime_ipv6_disable_guard_absent "$ip6t" || exit 1
  fi

  if [ "$BLOCK_QUIC" -eq 1 ]; then
    for chain in INPUT FORWARD OUTPUT; do
      "$ipt" -w 5 -t filter -C "$chain" -j BLOCK_QUIC 2>/dev/null || exit 1
      if [ "$PROXY_IPV6" -eq 1 ]; then
        "$ip6t" -w 5 -t filter -C "$chain" -j BLOCK_QUIC6 2>/dev/null || exit 1
      fi
    done
  fi

  if [ "$BYPASS_CN_IP" -eq 1 ]; then
    _runtime_ipset_exists cnip || exit 1
    if [ "$PROXY_IPV6" -eq 1 ]; then
      _runtime_ipset_exists cnip6 || exit 1
    fi
  fi

  # DNS hijack mode 1 leaves helper chains in mangle; mode 2 installs NAT
  # REDIRECT chains even under USE_TPROXY. Mode 0 skips these probes.
  if [ "$DNS_HIJACK_ENABLE" -eq 1 ] && [ "$USE_TPROXY" -eq 1 ]; then
    "$ipt" -w 5 -t mangle -L DNS_HIJACK_PRE -n >/dev/null 2>&1 || exit 1
    "$ipt" -w 5 -t mangle -L DNS_HIJACK_OUT -n >/dev/null 2>&1 || exit 1
  elif [ "$DNS_HIJACK_ENABLE" -eq 2 ]; then
    "$ipt" -w 5 -t nat -L NAT_DNS_HIJACK -n >/dev/null 2>&1 || exit 1
    "$ipt" -w 5 -t nat -C OUTPUT -j NAT_DNS_HIJACK 2>/dev/null || exit 1
  fi

  [ "$ipv6_drift" -eq 0 ] || exit 2
  exit 0
)

runtime_tproxy_state_ready() {
  if runtime_tproxy_state_classify "$@"; then
    return 0
  fi
  return 1
}

runtime_trim_log() {
  local file="$1"
  local max_bytes="$2"
  local keep_bytes="$3"
  local size tmp

  [ -f "$file" ] && [ ! -L "$file" ] || return 0
  case "$max_bytes:$keep_bytes" in
    *[!0-9:]*|:*) return 1 ;;
  esac
  [ "$keep_bytes" -gt 0 ] && [ "$keep_bytes" -lt "$max_bytes" ] || return 1
  size=$($busybox stat -c %s "$file" 2>/dev/null) || return 1
  [ "$size" -le "$max_bytes" ] && return 0

  tmp="${file}.trim.$$"
  $busybox tail -c "$keep_bytes" "$file" > "$tmp" 2>/dev/null || {
    rm -f "$tmp"
    return 1
  }
  # Copy back into the existing inode. Renaming would leave sing-box writing to
  # the old file descriptor and would not actually bound the live log.
  $busybox cat "$tmp" > "$file" 2>/dev/null || {
    rm -f "$tmp"
    return 1
  }
  rm -f "$tmp"
}

runtime_trim_logs() {
  local run_dir="$1"
  runtime_trim_log "${run_dir}/runs.log" 524288 262144 || true
  runtime_trim_log "${run_dir}/net.log" 1048576 524288 || true
  runtime_trim_log "${run_dir}/sing-box.log" 2097152 1048576 || true
}
