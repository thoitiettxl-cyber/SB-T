{
  "log": {
    "level": "warning",
    "output": "/data/adb/box/run/sing-box.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "https",
        "tag": "remote_dns",
        "server": "8.8.8.8"
      },
      {
        "type": "fakeip",
        "tag": "fake_dns",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "domain": [
          "mdp-appconf-row.heytapdl.com"
        ],
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
      {
        "query_type": [
          "SVCB",
          "HTTPS"
        ],
        "action": "predefined",
        "rcode": "NOTIMP"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": "category-ads-all"
          }
        ],
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
      {
        "rule_set": "geosite-telegram",
        "server": "remote_dns"
      },
      {
        "domain_suffix": [
          ".vertexaisearch.cloud.google.com",
          ".cloud.google.com",
          ".googleapis.com",
          "vertexaisearch.cloud.google.com"
        ],
        "server": "remote_dns"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "fake_dns",
        "rewrite_ttl": 60
      }
    ],
    "final": "remote_dns",
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7080
    },
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "::",
      "listen_port": 1536,
      "udp_timeout": "1m"
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "Default_🦈",
      "outbounds": [
        "Direct_🦈"
      ],
      "default": "Direct_🦈",
      "interrupt_exist_connections": true
    },
    {
      "type": "direct",
      "tag": "Direct_🦈"
    },
    {
      "type": "selector",
      "tag": "Soul_🌐",
      "outbounds": [
        "Direct_🦈"
      ]
    }
  ],
  "route": {
    "rules": [
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "port": 853,
        "action": "reject"
      },
      {
        "network": "udp",
        "port": 443,
        "action": "reject"
      },
      {
        "action": "sniff",
        "timeout": "100ms"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": "category-ads-all"
          }
        ],
        "action": "reject"
      },
      {
        "protocol": "stun",
        "action": "reject"
      },
      {
        "network": "icmp",
        "outbound": "Direct_🦈"
      },
      {
        "domain_suffix": [
          ".vertexaisearch.cloud.google.com",
          ".cloud.google.com",
          ".googleapis.com",
          "vertexaisearch.cloud.google.com"
        ],
        "outbound": "Default_🦈"
      },
      {
        "network": [
          "tcp",
          "udp"
        ],
        "outbound": "Default_🦈"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "category-ads-all",
        "url": "https://github.com/thaomaitam/Geosite-vn/raw/rule-set/Geosite-vn.srs",
        "download_detour": "Direct_🦈",
        "update_interval": "24h0m0s"
      },
      {
        "tag": "geosite-telegram",
        "type": "remote",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/sing/geo-lite/geosite/telegram.srs",
        "download_detour": "Direct_🦈",
        "update_interval": "24h0m0s"
      }
    ],
    "final": "Default_🦈",
    "find_process": false,
    "auto_detect_interface": true,
    "default_domain_resolver": "remote_dns"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "store_fakeip": true,
      "store_rdrc": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
      "external_ui_download_detour": "Direct_🦈",
      "default_mode": "rule"
    }
  }
}
